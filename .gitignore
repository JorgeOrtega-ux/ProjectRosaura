# Archivos de entorno con credenciales sensibles
.env
.env.*
!.env.example

# Archivos del sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Directorios de dependencias
vendor/
node_modules/

# Archivos de logs generales
*.log
error_log

# === IGNORAR LA CARPETA DEL NUEVO SISTEMA DE LOGS ===
/logs/
!/logs/.gitkeep

# === IGNORAR COPIAS DE SEGURIDAD DE LA BASE DE DATOS ===
storage/backups/*.sql
storage/backups/*.enc
storage/backups/*.gz
!storage/backups/.htaccess

# === IGNORAR ARCHIVOS MULTIMEDIA DEL STUDIO ===
storage/temp_videos/*
!storage/temp_videos/.gitkeep
public/storage/videos/*
!public/storage/videos/.gitkeep
public/storage/thumbnails/*
!public/storage/thumbnails/.gitkeep
!public/storage/thumbnails/default/

# Ignorar archivos generados por editores / IDEs
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln