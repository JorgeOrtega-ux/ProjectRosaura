# Archivos de entorno con credenciales sensibles
.env
.env.*
!.env.example

# Archivos del sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Directorios de dependencias
vendor/
node_modules/

# Archivos de logs generales
*.log
error_log

# === IGNORAR LA CARPETA DEL NUEVO SISTEMA DE LOGS ===
/logs/
!/logs/.gitkeep

# === IGNORAR COPIAS DE SEGURIDAD DE LA BASE DE DATOS ===
storage/backups/*.sql
storage/backups/*.enc
storage/backups/*.gz
!storage/backups/.htaccess

# === BLOQUEO ESTRICTO: DATOS SENSIBLES Y ARCHIVOS BINARIOS ===

# Ignorar la base de datos binaria de GeoIP
/storage/geoip/*.mmdb

# Ignorar todas las fotos de perfil (tanto las predeterminadas como las subidas)
/public/storage/profilePictures/default/*
/public/storage/profilePictures/uploaded/*
!/public/storage/profilePictures/.htaccess

# Ignorar archivos generados por editores / IDEs
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln