<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # IMPORTANTE: +FollowSymLinks es obligatorio en servidores Windows para mod_rewrite
    Options +FollowSymLinks -Indexes -MultiViews

    # Base de tu proyecto local
    RewriteBase /

    # 1. Enrutar archivos estáticos (JS, CSS)
    RewriteRule ^assets/(.*)$ public/assets/$1 [L]

    # =========================================================================
    # 2. MAGIA DE APACHE: TRADUCTOR VIRTUAL DE STORAGE (Evita el bug de Docker)
    # =========================================================================
    # Si el navegador pide /public/storage/..., Apache buscará físicamente en /storage/public/...
    RewriteRule ^public/storage/(.*)$ storage/public/$1 [L]

    # 3. Si la petición ya está apuntando a public/ internamente, la dejamos pasar
    RewriteRule ^public/ - [L]

    # 4. Si piden un archivo físico que SÍ existe (ej. un .png), dejarlo pasar
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # 5. Cualquier otra petición (incluyendo la raíz y las rutas SPA) va al index.php
    RewriteRule ^(.*)$ public/index.php [QSA,L]
</IfModule>