<IfModule mod_rewrite.c>
    RewriteEngine On
    Options +FollowSymLinks -Indexes -MultiViews

    RewriteBase /ProjectRosaura/

    # Archivos estáticos y de almacenamiento público
    RewriteRule ^assets/(.*)$ public/assets/$1 [L]
    RewriteRule ^storage/(.*)$ public/storage/$1 [L]
    RewriteRule ^public/ - [L]

    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # ---> REGLA HLS CORREGIDA: Debe inyectar route=media.stream
    # Y estar ANTES de la regla del Frontend
    RewriteRule ^api/media/stream/([a-zA-Z0-9-]+)/(.*)$ api/index.php?route=media.stream&v=$1&f=$2 [QSA,L]

    # Cualquier otra petición va al Frontend (SPA)
    RewriteRule ^(.*)$ public/index.php [QSA,L]
</IfModule>

<IfModule mod_xsendfile.c>
    XSendFile On
</IfModule>