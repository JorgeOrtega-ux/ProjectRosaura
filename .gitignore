# Archivos de entorno con credenciales sensibles
.env
.env.*
!.env.example

# Archivos del sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# Directorios de dependencias
vendor/
node_modules/

# Archivos de logs generales
*.log
error_log

# === IGNORAR LA CARPETA DEL NUEVO SISTEMA DE LOGS ===
/storage/private/logs/
!/storage/private/logs/.gitkeep

# === TIMELAPSES DE LIENZOS (ARCHIVOS FÍSICOS) ===
storage/private/canvases/timelapses/*.jsonl
!storage/private/canvases/timelapses/.htaccess
!storage/private/canvases/timelapses/.gitkeep

# === IGNORAR COPIAS DE SEGURIDAD DE LA BASE DE DATOS ===
storage/private/backups/*.sql
storage/private/backups/*.enc
storage/private/backups/*.gz
!storage/private/backups/.htaccess

# === BLOQUEO ESTRICTO: DATOS SENSIBLES Y ARCHIVOS BINARIOS ===

# Ignorar la base de datos binaria de GeoIP
/storage/private/geoip/*.mmdb

# Ignorar todas las fotos de perfil (tanto las predeterminadas como las subidas)
/storage/public/profilePictures/default/*
/storage/public/profilePictures/uploaded/*
!/storage/public/profilePictures/.htaccess

# Ignorar el symlink generado dinámicamente
/public/storage

# Ignorar archivos generados por editores / IDEs
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln


# Ignorar archivos generados dinámicamente en el storage público
/storage/public/snapshots/
/storage/public/snapshots_archive/
/storage/public/templates/